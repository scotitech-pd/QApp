{
  "name": "q-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace web",
    "dev:api": "npm run dev --workspace api",
    "dev:lan:web": "npm run dev --workspace web -- --hostname 0.0.0.0 --port 3000",
    "dev:lan:api": "HOST=0.0.0.0 npm run dev --workspace api",
    "build:web": "npm run build --workspace web",
    "build:api": "npm run build --workspace api",
    "start:api": "npm run start --workspace api",
    "seed:demo": "node prisma/seed-demo.mjs",
    "seed:real-shop": "node scripts/seed-real-shop.mjs",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "contract:test:mobile": "node scripts/check-mobile-contract.mjs",
    "typecheck:web": "npm run typecheck --workspace web",
    "typecheck:api": "npm run typecheck --workspace api"
  },
  "devDependencies": {
    "prisma": "^6.9.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
